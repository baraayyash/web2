PORT=3000
# Matches docker-compose.yml (run: docker compose up -d)
MONGODB_URI=mongodb://admin:changeme@127.0.0.1:27018/expressouth2v0?authSource=admin
JWT_SECRET=change-this-to-a-long-random-string
SESSION_SECRET=another-long-random-string

# Google OAuth — create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=xx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xx
# Must match an authorized redirect URI in Google Cloud (e.g. http://localhost:3000/api/auth/google/callback)
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback
# Where to send the browser after Google login (JWT appended as query param)
CLIENT_SUCCESS_URL=http://localhost:3000
